# Copy to .env locally; on Railway, set each value in the service's Variables tab.

# AWS Bedrock (Claude + Titan Embeddings)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Main reasoning/tool-use model. Use a Claude Sonnet inference profile for the best
# investment-reasoning + tool routing, e.g. us.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
# Optional cheaper model for routing/grading (multi-agent + agentic RAG). Falls back
# to BEDROCK_MODEL_ID if unset.
BEDROCK_ROUTING_MODEL_ID=
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
# Cache the static system prompt + tool schemas across tool-loop iterations. Enable
# only on a model that supports Bedrock prompt caching (Claude). Leave off on Llama.
ENABLE_PROMPT_CACHING=false

# Bedrock image generation (Stability) — separate region
BEDROCK_IMAGE_REGION=us-west-2
BEDROCK_IMAGE_MODEL_ID=stability.stable-image-core-v1:1

# S3 assets bucket (used for Textract + reading project images)
S3_ASSETS_REGION=eu-west-2

# Supabase Postgres (use the connection pooler host)
DB_HOST=aws-1-ap-south-1.pooler.supabase.com
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=postgres

# HeyGen
HEYGEN_API_KEY=

# Property Monitor AVM API (valuations + rental/yield data). Two key headers.
PM_API_KEY=1b5ef66e5663c7593fda12397f6c95e29ff21a96
PM_COMPANY_KEY=6Rz6SwR4r8pZdK8Pkswn67FuCeCokEZ71g2ft2J4
PM_BASE_URL=https://api.propertymonitor.com

# Telegram bot (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Tighten CORS to your Next.js domain(s) in production. Comma-separated.
# CORS_ORIGINS=https://your-site.com,https://www.your-site.com
CORS_ORIGINS=*

# Misc
LOG_LEVEL=INFO
APP_ENV=production
