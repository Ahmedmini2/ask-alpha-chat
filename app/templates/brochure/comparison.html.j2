<!DOCTYPE html>
<!-- Allegiance "Side by Side" property comparison — single A4 portrait sheet.
     2–3 projects ranked on price, size, yield, appreciation and the Alpha Score
     verdict. Rendered headless to PDF. -->
<html lang="en">
<head>
<meta charset="utf-8">
<title>Property Comparison | Allegiance Real Estate</title>
<style>
:root{
  --pine:#06342C;
  --gold:#C1A777;
  --gold-deep:#8F7748;
  --ink:#16191D;
  --slate:#5A646E;
  --slate-soft:#98A1AA;
  --hairline:#E5E1D8;
  --hairline-soft:#EFECE4;
  --paper:#FFFFFF;
  --paper-warm:#FAF7F0;
  --lime:#8CC63F;
  --lime-deep:#79B23A;
  --serif-display:"Vanitas","Marcellus",Georgia,serif;
  --serif-alt:"Marcellus",Georgia,serif;
  --sans:"Google Sans Flex",system-ui,Arial,sans-serif;
  --labelw:{{ label_w }};
  --photoh:{{ '116px' if n >= 3 else '150px' }};
}
{% if vanitas_font %}
@font-face{ font-family:"Vanitas"; src:url("{{ static_dir }}/fonts/{{ vanitas_font }}"); font-weight:400; font-display:block; }
{% endif %}
@font-face{ font-family:"Marcellus"; src:url("{{ static_dir }}/fonts/Marcellus-Regular.ttf"); font-weight:400; font-display:block; }
@font-face{ font-family:"Google Sans Flex"; src:url("{{ static_dir }}/fonts/GoogleSansFlex-Regular.ttf"); font-weight:400; font-display:block; }
@font-face{ font-family:"Google Sans Flex"; src:url("{{ static_dir }}/fonts/GoogleSansFlex-Medium.ttf"); font-weight:500; font-display:block; }
@font-face{ font-family:"Google Sans Flex"; src:url("{{ static_dir }}/fonts/GoogleSansFlex-SemiBold.ttf"); font-weight:600; font-display:block; }
@font-face{ font-family:"Google Sans Flex"; src:url("{{ static_dir }}/fonts/GoogleSansFlex-Bold.ttf"); font-weight:700; font-display:block; }

*{box-sizing:border-box;}
html,body{margin:0;padding:0;background:#fff;}
body{font-family:var(--sans);-webkit-font-smoothing:antialiased;}

.sheet{
  width:794px; height:1123px; background:var(--paper);
  position:relative; overflow:hidden;
  padding:36px 40px 26px; display:flex; flex-direction:column;
}

/* ---- header ---- */
.cmp__eyebrow{ font-family:var(--sans); font-weight:600; font-size:10.5px; letter-spacing:.3em; text-transform:uppercase; color:var(--gold-deep); }
.cmp__eyebrow .slash{ color:var(--gold); margin-right:5px; }
.cmp__title{ font-family:var(--serif-display); font-weight:400; font-size:46px; line-height:1; letter-spacing:.04em; text-transform:uppercase; color:var(--pine); margin:8px 0 9px; }
.cmp__sub{ font-size:12.5px; line-height:1.5; color:var(--slate); margin:0; max-width:640px; }
.cmp__rule{ height:1px; background:var(--hairline); margin:16px 0 0; }

/* ---- shared grid (label gutter + N value columns) ---- */
.grid{ display:grid; grid-template-columns:var(--labelw) repeat({{ n }},1fr); }

/* ---- property header cards ---- */
.heads{ padding:20px 0 4px; align-items:end; }
.head{ padding:0 14px; text-align:center; display:flex; flex-direction:column; align-items:center; }
.head__photo{ width:100%; max-width:240px; height:var(--photoh); border-radius:6px; overflow:hidden; background:#e9e7e0; margin-bottom:14px; }
.head__photo img{ width:100%; height:100%; object-fit:cover; display:block; }
.head__photo.empty{ display:flex; align-items:center; justify-content:center; }
.head__name{ font-family:var(--serif-alt); font-size:20px; line-height:1.12; color:var(--pine); letter-spacing:.01em; }
.head__loc{ font-family:var(--serif-alt); font-size:11.5px; line-height:1.3; color:var(--slate); margin-top:7px; }
.head__dash{ width:26px; height:2px; background:var(--gold); margin:11px 0 9px; }
.head__price{ font-family:var(--sans); font-weight:700; font-size:25px; color:var(--pine); letter-spacing:-.01em; }

/* ---- at a glance ---- */
.cmp__atglance{ font-family:var(--sans); font-weight:600; font-size:9.5px; letter-spacing:.26em; text-transform:uppercase; color:var(--slate-soft); margin:14px 0 2px; }

/* ---- metric rows ---- */
.rows{ display:flex; flex-direction:column; flex:1; min-height:0; justify-content:flex-start; }
.row{ display:grid; grid-template-columns:var(--labelw) repeat({{ n }},1fr); align-items:center; border-top:1px solid var(--hairline); min-height:0; }
.row__label{ display:flex; align-items:center; gap:10px; padding:0 6px; }
.row__label svg{ width:17px; height:17px; flex:none; stroke-width:1.5; color:var(--gold-deep); }
.row__label span{ font-family:var(--sans); font-weight:600; font-size:10px; letter-spacing:.13em; text-transform:uppercase; color:var(--slate); line-height:1.2; }
.cell{ position:relative; padding:13px 14px; display:flex; align-items:center; justify-content:center; gap:8px; min-width:0; }
.cell.div::before{ content:""; position:absolute; left:0; top:50%; transform:translateY(-50%); width:1px; height:58%; background:var(--hairline); }
.cell .val{ font-family:var(--sans); font-weight:600; font-size:15px; color:var(--ink); line-height:1.2; text-align:center; }
.cell.win .val{ font-weight:700; color:var(--pine); }
.cell .val small{ font-weight:500; font-size:11px; color:var(--slate); }
.badge{ font-family:var(--sans); font-weight:700; font-size:8px; letter-spacing:.1em; text-transform:uppercase; color:#fff; background:var(--lime); padding:3px 6px 2px; border-radius:3px; line-height:1; white-space:nowrap; flex:none; }

/* ---- alpha score band ---- */
.alpha{ border-top:0; background:linear-gradient(100deg,var(--lime) 0%,var(--lime-deep) 100%); border-radius:9px; margin-top:14px; overflow:hidden; }
.alpha .row__label{ padding:20px 18px; }
.alpha .row__label svg{ color:#fff; width:19px; height:19px; }
.alpha .row__label span{ color:#fff; font-size:11px; letter-spacing:.18em; }
.alpha .cell{ padding:20px 14px; }
.alpha .cell.div::before{ background:rgba(255,255,255,.35); height:64%; }
.alpha .ascore{ font-family:var(--sans); font-weight:700; font-size:30px; color:#fff; line-height:1; letter-spacing:-.01em; }
.alpha .aslash{ font-family:var(--sans); font-weight:600; font-size:13px; color:rgba(255,255,255,.8); margin-left:1px; }
.alpha .badge{ background:#fff; color:var(--lime-deep); }

/* ---- footer ---- */
.cmp__foot{ margin-top:18px; display:flex; flex-direction:column; align-items:center; gap:7px; }
.cmp__foot img{ height:46px; width:auto; display:block; }
.cmp__foot .cities{ font-family:var(--sans); font-weight:500; font-size:8.5px; letter-spacing:.24em; text-transform:uppercase; color:var(--slate-soft); white-space:nowrap; }

@media print{
  @page{ size:A4 portrait; margin:0; }
  html,body{ background:#fff; }
  .sheet{ box-shadow:none; }
}
</style>
</head>
<body>
{% macro icon(name) -%}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
{%- if name == 'tag' -%}
<path d="M20.6 13.4 13.4 20.6a2 2 0 0 1-2.8 0L3 13V3h10l7.6 7.6a2 2 0 0 1 0 2.8z"/><circle cx="7.5" cy="7.5" r="1.4" fill="currentColor" stroke="none"/>
{%- elif name == 'home' -%}
<path d="M3 10.5 12 3.5l9 7M5 9.3V21h14V9.3M9.5 21v-6h5v6"/>
{%- elif name == 'bed' -%}
<path d="M3 18v-6a2 2 0 0 1 2-2h11a4 4 0 0 1 4 4v4M3 14.5h18M3 18v2M21 18v2"/><circle cx="7.5" cy="11.5" r="1.6"/>
{%- elif name == 'bath' -%}
<path d="M9 6 6.5 3.6A1.6 1.6 0 0 0 4 4.8V12M3 12h18v2.5a5 5 0 0 1-5 5H8a5 5 0 0 1-5-5z"/><path d="M7 19.5 5.6 21.5M18.4 21.5 17 19.5"/>
{%- elif name == 'area' -%}
<path d="M8 3H5a2 2 0 0 0-2 2v3M16 3h3a2 2 0 0 1 2 2v3M21 16v3a2 2 0 0 1-2 2h-3M3 16v3a2 2 0 0 0 2 2h3"/>
{%- elif name == 'percent' -%}
<line x1="19" y1="5" x2="5" y2="19"/><circle cx="6.6" cy="6.6" r="2.4"/><circle cx="17.4" cy="17.4" r="2.4"/>
{%- elif name == 'trend' -%}
<path d="M3 17 9.5 10.5l4 4L21 7"/><path d="M15 7h6v6"/>
{%- elif name == 'calendar' -%}
<rect x="3" y="4.5" width="18" height="17" rx="2"/><path d="M3 9.5h18M8 2.5v4M16 2.5v4"/><circle cx="12" cy="15" r="2.4"/>
{%- elif name == 'gauge' -%}
<path d="M3.5 18a8.5 8.5 0 0 1 17 0"/><path d="M12 18l4.6-5"/><circle cx="12" cy="18" r="1.4" fill="currentColor" stroke="none"/>
{%- else -%}
<circle cx="12" cy="12" r="9"/>
{%- endif -%}
</svg>
{%- endmacro %}

<section class="sheet">

  <div class="cmp__eyebrow"><span class="slash">//</span> Side by Side</div>
  <h1 class="cmp__title">Property Comparison</h1>
  <p class="cmp__sub">{{ subtitle }}</p>
  <div class="cmp__rule"></div>

  <!-- property header cards -->
  <div class="grid heads">
    <div></div>
    {% for p in properties %}
    <div class="head">
      <div class="head__photo{% if not p.image %} empty{% endif %}">
        {% if p.image %}<img src="{{ p.image }}" alt="{{ p.name }}">{% endif %}
      </div>
      <div class="head__name">{{ p.name }}</div>
      <div class="head__loc">{{ p.location }}</div>
      <div class="head__dash"></div>
      <div class="head__price">{{ p.price }}</div>
    </div>
    {% endfor %}
  </div>

  <div class="cmp__atglance">At a Glance</div>

  <div class="rows">
    {% for r in rows %}
    <div class="row">
      <div class="row__label">{{ icon(r.icon) }}<span>{{ r.label }}</span></div>
      {% for c in r.cells %}
      <div class="cell{% if not loop.first %} div{% endif %}{% if c.is_win %} win{% endif %}">
        <span class="val">{{ c.disp }}</span>
        {% if c.is_win and r.badge %}<span class="badge">{{ r.badge }}</span>{% endif %}
      </div>
      {% endfor %}
    </div>
    {% endfor %}

    <div class="row alpha">
      <div class="row__label">{{ icon('gauge') }}<span>{{ alpha.label }}</span></div>
      {% for c in alpha.cells %}
      <div class="cell{% if not loop.first %} div{% endif %}">
        <span class="ascore">{{ c.disp }}</span>{% if c.disp != '—' %}<span class="aslash">/100</span>{% endif %}
        {% if c.is_win and alpha.badge %}<span class="badge">{{ alpha.badge }}</span>{% endif %}
      </div>
      {% endfor %}
    </div>
  </div>

  <div class="cmp__foot">
    <img src="{{ static_dir }}/allegiance-green.png" alt="Allegiance Real Estate">
    <div class="cities">Dubai · Sydney · Riyadh · Paris · Beirut · Tokyo · Ljubljana</div>
  </div>

</section>

<script>
  // No map/network assets on this sheet — signal ready immediately.
  window.__MAP_READY__ = true;
</script>
</body>
</html>
