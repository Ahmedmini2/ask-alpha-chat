{
  "family": "askalpha-bot",
  "requiresCompatibilities": ["FARGATE"],
  "networkMode": "awsvpc",
  "cpu": "512",
  "memory": "1024",
  "runtimePlatform": { "cpuArchitecture": "X86_64", "operatingSystemFamily": "LINUX" },
  "executionRoleArn": "arn:aws:iam::${ACCT}:role/askalpha-exec",
  "taskRoleArn": "arn:aws:iam::${ACCT}:role/askalpha-task",
  "containerDefinitions": [
    {
      "name": "bot",
      "image": "${ECR}:latest",
      "essential": true,
      "command": ["python", "-m", "app.integrations.telegram.bot"],
      "environment": [
        { "name": "APP_ENV", "value": "production" },
        { "name": "LOG_LEVEL", "value": "INFO" },
        { "name": "AWS_REGION", "value": "us-east-1" },
        { "name": "BEDROCK_MODEL_ID", "value": "${BEDROCK_MODEL_ID}" },
        { "name": "BEDROCK_EMBED_MODEL_ID", "value": "amazon.titan-embed-text-v2:0" },
        { "name": "S3_ASSETS_REGION", "value": "eu-west-2" },
        { "name": "GEMINI_IMAGE_MODEL_ID", "value": "gemini-3-pro-image-preview" }
      ],
      "secrets": [
        { "name": "DB_HOST", "valueFrom": "${SECRET_ARN}:DB_HOST::" },
        { "name": "DB_PORT", "valueFrom": "${SECRET_ARN}:DB_PORT::" },
        { "name": "DB_USER", "valueFrom": "${SECRET_ARN}:DB_USER::" },
        { "name": "DB_PASSWORD", "valueFrom": "${SECRET_ARN}:DB_PASSWORD::" },
        { "name": "DB_NAME", "valueFrom": "${SECRET_ARN}:DB_NAME::" },
        { "name": "SUPABASE_URL", "valueFrom": "${SECRET_ARN}:SUPABASE_URL::" },
        { "name": "HEYGEN_API_KEY", "valueFrom": "${SECRET_ARN}:HEYGEN_API_KEY::" },
        { "name": "TELEGRAM_BOT_TOKEN", "valueFrom": "${SECRET_ARN}:TELEGRAM_BOT_TOKEN::" },
        { "name": "DESCRIPT_API_TOKEN", "valueFrom": "${SECRET_ARN}:DESCRIPT_API_TOKEN::" },
        { "name": "FAL_KEY", "valueFrom": "${SECRET_ARN}:FAL_KEY::" },
        { "name": "AYRSHARE_API_KEY", "valueFrom": "${SECRET_ARN}:AYRSHARE_API_KEY::" },
        { "name": "PM_API_KEY", "valueFrom": "${SECRET_ARN}:PM_API_KEY::" },
        { "name": "PM_COMPANY_KEY", "valueFrom": "${SECRET_ARN}:PM_COMPANY_KEY::" },
        { "name": "GOOGLE_AI_STUDIO_API_KEY", "valueFrom": "${SECRET_ARN}:GOOGLE_AI_STUDIO_API_KEY::" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/askalpha",
          "awslogs-region": "${REGION}",
          "awslogs-stream-prefix": "bot"
        }
      }
    }
  ]
}
